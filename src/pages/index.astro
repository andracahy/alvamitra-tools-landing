---
import Base from '../layouts/Base.astro';
import Hero from '../components/sections/Hero.astro';
import ValueBand from '../components/sections/ValueBand.astro';
import Workflow from '../components/sections/Workflow.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Footer from '../components/sections/Footer.astro';
import DemoIsland from '../components/islands/DemoIsland';
import { IconArrow } from '../components/icons';
import { GROUPS } from '../data/content';
---

<Base>
  <Hero />
  <ValueBand />

  <section id="tools" class="wrap section">
    <div class="sec-intro reveal">
      <div class="kicker">Tools</div>
      <h2>Coba langsung sebelum membuka tool penuh</h2>
      <p>Setiap kartu punya demo mini interaktif — geser dan klik untuk merasakan cara kerjanya. Siap menghitung serius? Buka tool versi lengkapnya.</p>
    </div>
    {GROUPS.map((g) => (
      <div class="group">
        <div class="group-label reveal">{g.label}</div>
        <div class="group-grid">
          {g.tools.map((t, i) => {
            const Ico = t.ico;
            return (
              <article class="tcard reveal" style={`transition-delay: ${i * 80}ms`} data-screen-label={t.name} data-pixel-event={t.pixelEvent}>
                <div class="tcard-top">
                  <div class="tbadge"><Ico size={23} /></div>
                  <div class="meta">
                    <h3>{t.name}</h3>
                    <div class="id-sub">{t.sub}</div>
                  </div>
                  <span class="demo-pill"><i></i>Demo</span>
                </div>
                <p class="desc">{t.desc}</p>
                <div class="when"><b>Kapan dipakai:</b> {t.when}.</div>
                <DemoIsland id={t.demo} client:only="react" />
                <div class="tcard-foot">
                  <a class="tcta" href={t.url}><span>Buka tool lengkap</span><IconArrow className="arrow" size={17} /></a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    ))}
  </section>

  <Workflow />
  <FinalCTA />
  <Footer />
</Base>

<script>
  // Scroll reveal — reveal in-view items langsung, observe sisanya, fail-safe.
  const els = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));
  const show = (e: Element) => e.classList.add('in');
  const inView = (e: Element) => {
    const r = e.getBoundingClientRect();
    return r.top < window.innerHeight * 0.95 && r.bottom > 0;
  };
  els.forEach((e) => { if (inView(e)) show(e); });
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((en) => { if (en.isIntersecting) { show(en.target); io.unobserve(en.target); } });
    }, { threshold: 0.1, rootMargin: '0px 0px -6% 0px' });
    els.forEach((e) => { if (!e.classList.contains('in')) io.observe(e); });
    setTimeout(() => els.forEach(show), 2500);
  } else {
    els.forEach(show);
  }
  // Meta Pixel event tracking
  const w = window as unknown as Record<string, (...a: unknown[]) => void>;
  const fbq = (...args: unknown[]) => { if (typeof w.fbq === 'function') w.fbq(...args); };

  // ViewContent — saat section tools pertama kali terlihat
  const toolsSection = document.getElementById('tools');
  if (toolsSection && 'IntersectionObserver' in window) {
    const viewIo = new IntersectionObserver((entries) => {
      entries.forEach((en) => {
        if (en.isIntersecting) {
          fbq('track', 'ViewContent', { content_name: 'Tools Section' });
          viewIo.unobserve(en.target);
        }
      });
    }, { threshold: 0.2 });
    viewIo.observe(toolsSection);
  }

  // Custom event spesifik per tool (SelectCCTVCalculator, SelectViewingAngle, dst.)
  document.querySelectorAll<HTMLAnchorElement>('.tcta').forEach((btn) => {
    btn.addEventListener('click', () => {
      const card = btn.closest<HTMLElement>('[data-pixel-event]');
      const eventName = card?.dataset.pixelEvent ?? 'SelectTool';
      fbq('trackCustom', eventName);
    });
  });

  // Lead — klik tombol CTA utama (Hero & Final CTA)
  document.querySelector<HTMLAnchorElement>('.btn-primary')?.addEventListener('click', () => {
    fbq('track', 'Lead', { content_name: 'Hero CTA', content_category: 'cta' });
  });
  document.querySelector<HTMLAnchorElement>('.btn-white')?.addEventListener('click', () => {
    fbq('track', 'Lead', { content_name: 'Final CTA', content_category: 'cta' });
  });
</script>
