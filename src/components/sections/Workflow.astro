---
import { STEPS } from '../../data/content';
---

<section id="alur" class="flow">
  <div class="wrap section">
    <div class="sec-intro reveal">
      <div class="kicker">Alur kerja</div>
      <h2>Satu alur, dari survei sampai uji coba</h2>
      <p>Setiap tool memetakan satu tahap proyek CCTV. Pakai berurutan, dan tidak ada detail teknis yang terlewat.</p>
    </div>
    <div class="flow-grid">
      <div class="flow-line"></div>
      {STEPS.map((s, i) => (
        <div class="fstep reveal" style={`transition-delay: ${i * 90}ms`}>
          <div class="num">{s.n}</div>
          <h4>{s.t}</h4>
          <p>{s.d}</p>
          <div class="ftools">{s.tools.map((t) => <span>{t}</span>)}</div>
        </div>
      ))}
    </div>
  </div>
</section>
